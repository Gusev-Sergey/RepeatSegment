<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="RepeatSegment" Manufacturer="RepeatSegment"
           Version="1.1.0.0" UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
           Scope="perMachine" Compressed="yes">
    <MajorUpgrade Schedule="afterInstallInitialize"
                  DowngradeErrorMessage="A newer version is already installed." />
    <Media Id="1" Cabinet="RepeatSegment.cab" EmbedCab="yes" />

    <Feature Id="Main" Title="RepeatSegment" Level="1">
      <ComponentRef Id="ExeComponent" />
      <ComponentRef Id="ShortcutComponent" />
      <ComponentRef Id="IconIcoComponent" />
      <ComponentGroupRef Id="PublishComponents" />
    </Feature>

    <UI Id="MyWixUI">
      <ui:WixUI Id="WixUI_InstallDir" />
    </UI>

    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <Property Id="ARPCONTACT" Value="RepeatSegment Support" />
    <Property Id="ARPCOMMENTS" Value="Version 1.1, 2026. Python ported to C# via AI (VS Code + Zoo Code + DeepSeek API)" />
    <Icon Id="AppIcon" SourceFile="..\RepeatSegment.App\Icons\app.ico" />
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="RepeatSegment">
        <Directory Id="IconsDir" Name="Icons" />
      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="StartMenuDir" Name="RepeatSegment" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <Component Id="ExeComponent" Directory="INSTALLFOLDER" Guid="*">
      <File Id="AppExe" Source="..\Publish\RepeatSegment.App.exe" KeyPath="yes" />
    </Component>

    <Component Id="IconIcoComponent" Directory="IconsDir" Guid="*">
      <File Id="AppIco" Source="..\RepeatSegment.App\Icons\app.ico" KeyPath="yes" />
    </Component>

    <Component Id="ShortcutComponent" Directory="StartMenuDir" Guid="*">
      <RegistryValue Root="HKCU" Key="Software\RepeatSegment" Name="installed" Value="1" Type="integer" KeyPath="yes" />
      <Shortcut Id="StartMenuShortcut" Name="RepeatSegment" Target="[INSTALLFOLDER]RepeatSegment.App.exe"
                WorkingDirectory="INSTALLFOLDER" Icon="AppIcon" Advertise="no" />
      <Shortcut Id="DesktopShortcut" Directory="DesktopFolder" Name="RepeatSegment"
                Target="[INSTALLFOLDER]RepeatSegment.App.exe"
                WorkingDirectory="INSTALLFOLDER" Icon="AppIcon" Advertise="no" />
      <RemoveFolder Id="RemoveStartMenu" Directory="StartMenuDir" On="uninstall" />
    </Component>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="PublishComponents" Directory="IconsDir">
      <Component Id="IconBtnPlay" Guid="*"><File Source="..\Publish\Icons\btn_play.png" KeyPath="yes" /></Component>
      <Component Id="IconFirst" Guid="*"><File Source="..\Publish\Icons\first.png" KeyPath="yes" /></Component>
      <Component Id="IconLast" Guid="*"><File Source="..\Publish\Icons\last.png" KeyPath="yes" /></Component>
      <Component Id="IconNextPlay" Guid="*"><File Source="..\Publish\Icons\next_play.png" KeyPath="yes" /></Component>
      <Component Id="IconPlay" Guid="*"><File Source="..\Publish\Icons\play.png" KeyPath="yes" /></Component>
      <Component Id="IconPlayGo" Guid="*"><File Source="..\Publish\Icons\play_go.png" KeyPath="yes" /></Component>
      <Component Id="IconPrePlay" Guid="*"><File Source="..\Publish\Icons\pre_play.png" KeyPath="yes" /></Component>
      <Component Id="IconRepeat" Guid="*"><File Source="..\Publish\Icons\repeat.png" KeyPath="yes" /></Component>
      <Component Id="IconStopPlay" Guid="*"><File Source="..\Publish\Icons\stop_play.png" KeyPath="yes" /></Component>
    </ComponentGroup>
  </Fragment>

</Wix>
