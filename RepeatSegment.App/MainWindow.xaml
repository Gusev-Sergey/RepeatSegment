<Window x:Class="RepeatSegment.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:RepeatSegment.App"
        Title="RepeatSegment"
        Width="1040" Height="680"
        MinWidth="800" MinHeight="380"
        SizeToContent="Manual"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Segoe UI" FontSize="11pt">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F0F2F5"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextBrush" Color="#222222"/>
        <SolidColorBrush x:Key="TextDimBrush" Color="#666666"/>
        <SolidColorBrush x:Key="WaveformBgBrush" Color="#E8ECF0"/>
        <SolidColorBrush x:Key="SliderAccentBrush" Color="#3366CC"/>
        <SolidColorBrush x:Key="ButtonBgBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#E8F0FE"/>
        <SolidColorBrush x:Key="ButtonPressedBrush" Color="#E8F0FE"/>
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="MenuBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="MenuTextBrush" Color="#222222"/>
        <SolidColorBrush x:Key="MenuDropBgBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="StatusBarBrush" Color="#F0F2F5"/>
        <SolidColorBrush x:Key="SeparatorBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="VolumeBarBrush" Color="#56B4E9"/>
        <SolidColorBrush x:Key="VolumeBarBgBrush" Color="#DDDDDD"/>
        <SolidColorBrush x:Key="InputBgBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="WindowBackgroundBrush.Dark" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush.Dark" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="TextBrush.Dark" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextDimBrush.Dark" Color="#888888"/>
        <SolidColorBrush x:Key="WaveformBgBrush.Dark" Color="#252525"/>
        <SolidColorBrush x:Key="SliderAccentBrush.Dark" Color="#88AAFF"/>
        <SolidColorBrush x:Key="ButtonBgBrush.Dark" Color="#555555"/>
        <SolidColorBrush x:Key="ButtonHoverBrush.Dark" Color="#4A4A4A"/>
        <SolidColorBrush x:Key="ButtonPressedBrush.Dark" Color="#505050"/>
        <SolidColorBrush x:Key="ButtonBorderBrush.Dark" Color="#555555"/>
        <SolidColorBrush x:Key="MenuBackgroundBrush.Dark" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="MenuTextBrush.Dark" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="MenuDropBgBrush.Dark" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="StatusBarBrush.Dark" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="SeparatorBrush.Dark" Color="#555555"/>
        <SolidColorBrush x:Key="VolumeBarBrush.Dark" Color="#56B4E9"/>
        <SolidColorBrush x:Key="VolumeBarBgBrush.Dark" Color="#4A4A4A"/>
        <SolidColorBrush x:Key="InputBgBrush.Dark" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="InputBorderBrush.Dark" Color="#555555"/>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="{DynamicResource MenuDropBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource MenuTextBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" SharedSizeGroup="Icon"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto" SharedSizeGroup="Shortcut"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" x:Name="Icon" Margin="0,0,4,0" VerticalAlignment="Center" ContentSource="Icon" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                <ContentPresenter Grid.Column="1" ContentSource="Header" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                <TextBlock Grid.Column="2" x:Name="InputGestureText" Text="{TemplateBinding InputGestureText}" Margin="16,0,0,0" Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center"/>
                                <Path Grid.Column="3" x:Name="SubMenuArrow" Data="M 0 0 L 4 4 L 0 8 Z" Fill="{DynamicResource TextDimBrush}" Margin="8,0,0,0" VerticalAlignment="Center" Visibility="Collapsed"/>
                                <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False" IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}" PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}" Placement="Right">
                                    <Border x:Name="SubMenuBorder" Background="{DynamicResource MenuDropBgBrush}" BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="1" Padding="2">
                                        <ScrollViewer CanContentScroll="True" Style="{DynamicResource {ComponentResourceKey TypeInTargetAssembly={x:Type FrameworkElement}, ResourceId=MenuScrollViewer}}">
                                            <ItemsPresenter x:Name="ItemsPresenter" Grid.IsSharedSizeScope="True" KeyboardNavigation.DirectionalNavigation="Cycle" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Role" Value="TopLevelHeader"><Setter Property="Padding" Value="2,0,2,0"/><Setter TargetName="SubMenuArrow" Property="Visibility" Value="Collapsed"/><Setter TargetName="PART_Popup" Property="Placement" Value="Bottom"/></Trigger>
                            <Trigger Property="Role" Value="TopLevelItem"><Setter Property="Padding" Value="2,0,2,0"/><Setter TargetName="SubMenuArrow" Property="Visibility" Value="Collapsed"/></Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader"><Setter TargetName="SubMenuArrow" Property="Visibility" Value="Visible"/></Trigger>
                            <Trigger Property="IsHighlighted" Value="True"><Setter TargetName="Border" Property="Background" Value="{DynamicResource ButtonHoverBrush}"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Separator"><Setter Property="Background" Value="{DynamicResource SeparatorBrush}"/></Style>
        <Style TargetType="Button" x:Key="ImageButtonStyle">
            <Setter Property="Margin" Value="0"/><Setter Property="Padding" Value="2"/><Setter Property="Cursor" Value="Hand"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Grid Background="Transparent"><Border x:Name="HoverBorder" Background="Transparent" BorderThickness="0" CornerRadius="4" HorizontalAlignment="Center" VerticalAlignment="Center" Width="{TemplateBinding Width}" Height="{TemplateBinding Height}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/></Border></Grid><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="HoverBorder" Property="Background" Value="#20000000"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="HoverBorder" Property="Background" Value="#40000000"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="LayoutRoot">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*" MinHeight="140"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

        <Menu x:Name="MainMenu" Grid.Row="0" Background="{DynamicResource MenuBackgroundBrush}" Foreground="{DynamicResource MenuTextBrush}" FontSize="16" HorizontalAlignment="Left" Padding="0" Margin="6,0,0,0">
            <Menu.Resources><Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}"><Setter Property="Margin" Value="-4,0,-4,0"/></Style></Menu.Resources>
            <Menu.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></Menu.ItemsPanel>
            <MenuItem Header="File" FontSize="16" x:Name="MnuFile">
                <MenuItem x:Name="MnuFileLoad" Header="Load" Click="BtnLoad_Click" FontSize="16" InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem x:Name="MnuFileExit" Header="Exit" Click="BtnExit_Click" FontSize="16" InputGestureText="Alt+F4"/>
            </MenuItem>
            <MenuItem Header="Segment duration" FontSize="16" x:Name="MnuSplitInterval">
                <MenuItem Header="2 sec" Click="MnuSegmentDuration_Click" Tag="2" FontSize="16"/>
                <MenuItem Header="5 sec" Click="MnuSegmentDuration_Click" Tag="5" FontSize="16" IsChecked="True"/>
                <MenuItem Header="10 sec" Click="MnuSegmentDuration_Click" Tag="10" FontSize="16"/>
                <MenuItem Header="20 sec" Click="MnuSegmentDuration_Click" Tag="20" FontSize="16"/>
                <Separator/>
                <MenuItem x:Name="MnuSplitCustom" Header="Custom..." Click="MnuSegmentDurationCustom_Click" FontSize="16"/>
            </MenuItem>
            <MenuItem Header="Theme" FontSize="16" x:Name="MnuTheme">
                <MenuItem x:Name="MnuThemeLight" Header="Light" Click="MnuThemeLight_Click" FontSize="16"/>
                <MenuItem x:Name="MnuThemeDark" Header="Dark" Click="MnuThemeDark_Click" FontSize="16"/>
            </MenuItem>
            <MenuItem Header="Transcription" FontSize="16" x:Name="MnuTranscription">
                <MenuItem x:Name="MnuTranscriptionCache" Header="Load from cache" Click="BtnTranscribeCache_Click" FontSize="16" InputGestureText="Ctrl+L"/>
                <MenuItem x:Name="MnuTranscriptionApi" Header="Request from API" Click="BtnTranscribeApi_Click" FontSize="16" InputGestureText="Ctrl+T"/>
            </MenuItem>
            <MenuItem Header="Settings" FontSize="16" x:Name="MnuSettings">
                <MenuItem x:Name="MnuSettingsApiKeys" Header="API keys..." Click="ButtonSettings_Click" FontSize="16"/>
                <MenuItem x:Name="MnuSettingsTranslation" Header="Translation..." Click="ButtonTranslationSettings_Click" FontSize="16"/>
                <MenuItem x:Name="MnuSettingsGeneral" Header="General..." Click="ButtonGeneralSettings_Click" FontSize="16"/>
            </MenuItem>
            <MenuItem Header="Language" FontSize="16" x:Name="MnuLang">
                <MenuItem x:Name="MnuLangEn" Header="English" Click="MnuLangEn_Click" FontSize="16"/>
                <MenuItem x:Name="MnuLangRu" Header="Русский" Click="MnuLangRu_Click" FontSize="16"/>
            </MenuItem>
            <MenuItem Header="Help" FontSize="16" x:Name="MnuHelp">
                <MenuItem x:Name="MnuHelpGuide" Header="User Guide" Click="BtnManual_Click" FontSize="16"/>
                <Separator/>
                <MenuItem x:Name="MnuHelpAbout" Header="About..." Click="BtnAbout_Click" FontSize="16"/>
            </MenuItem>
        </Menu>

        <local:WaveformGraph Grid.Row="1" x:Name="WaveformGraph" Height="110" Margin="10,4" SegmentSelected="WaveformGraph_SegmentSelected"/>

        <Grid Grid.Row="2" Margin="10,4,10,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="LabelPosition" Grid.Column="0" Text="00:00" VerticalAlignment="Center" Foreground="{DynamicResource TextDimBrush}" FontSize="13"/>
            <Slider x:Name="SliderPosition" Grid.Column="1" Minimum="0" Maximum="100" Value="0" IsEnabled="False" Height="24" Cursor="Hand" ValueChanged="Slider_ValueChanged" Thumb.DragStarted="Slider_DragStarted" Thumb.DragCompleted="Slider_DragCompleted"/>
            <TextBlock x:Name="LabelDuration" Grid.Column="2" Text="00:00" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{DynamicResource TextDimBrush}" FontSize="13"/>
        </Grid>

        <Grid Grid.Row="3" Margin="10,6,10,4">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Button x:Name="BtnCollapseTranscription" Width="28" Height="28" Padding="0" Margin="0" HorizontalAlignment="Left" VerticalAlignment="Bottom" Click="BtnCollapseTranscription_Click" Background="{DynamicResource ButtonBgBrush}" BorderBrush="{DynamicResource ButtonBorderBrush}" Foreground="{DynamicResource TextBrush}" FontSize="14" Cursor="Hand" ToolTip="Show/Hide transcription">▲</Button>
            <Button x:Name="BtnSpeed" Width="28" Height="28" Padding="0" Margin="32,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Bottom" Click="BtnSpeed_Click" Background="{DynamicResource ButtonBgBrush}" BorderBrush="{DynamicResource ButtonBorderBrush}" Foreground="{DynamicResource TextBrush}" FontSize="11" FontWeight="Bold" Cursor="Hand" ToolTip="Playback speed">1×</Button>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="ButtonFirst" Style="{StaticResource ImageButtonStyle}" Click="ButtonFirst_Click" IsEnabled="False" ToolTip="First segment (Home)"><Image x:Name="ImgFirst" Source="Icons/first.png" Stretch="Uniform"/></Button>
                <Button x:Name="ButtonPrevSegment" Style="{StaticResource ImageButtonStyle}" Click="ButtonPrevSegment_Click" IsEnabled="False" ToolTip="Previous / Rewind (Left)"><Image x:Name="ImgPrev" Source="Icons/pre_play.png" Stretch="Uniform"/></Button>
                <Button x:Name="ButtonRepeat" Style="{StaticResource ImageButtonStyle}" Click="ButtonRepeat_Click" IsEnabled="False" ToolTip="Repeat segment (M)"><Image x:Name="ImgRepeat" Source="Icons/repeat.png" Stretch="Uniform"/></Button>
                <Button x:Name="ButtonPlayGo" Style="{StaticResource ImageButtonStyle}" Click="ButtonPlayGo_Click" IsEnabled="False" ToolTip="Play and Go to next (Ctrl+Space)"><Image x:Name="ImgPlayGo" Source="Icons/play_go.png" Stretch="Uniform"/></Button>
                <Button x:Name="ButtonPlay" Style="{StaticResource ImageButtonStyle}" Click="ButtonPlay_Click" IsEnabled="False" ToolTip="Play/Pause (Space)"><Image x:Name="ImgPlayPause" Source="Icons/play.png" Stretch="Uniform"/></Button>
                <Button x:Name="ButtonNextSegment" Style="{StaticResource ImageButtonStyle}" Click="ButtonNextSegment_Click" IsEnabled="False" ToolTip="Next / Forward (Right)"><Image x:Name="ImgNext" Source="Icons/next_play.png" Stretch="Uniform"/></Button>
                <Button x:Name="ButtonLast" Style="{StaticResource ImageButtonStyle}" Click="ButtonLast_Click" IsEnabled="False" ToolTip="Last segment (End)"><Image x:Name="ImgLast" Source="Icons/last.png" Stretch="Uniform"/></Button>
            </StackPanel>
            <local:VolumeWidget Grid.Column="2" x:Name="VolumeControl" Width="160" Height="44" HorizontalAlignment="Center" VerticalAlignment="Center" VolumeChanged="VolumeControl_VolumeChanged"/>
        </Grid>

        <Border Grid.Row="4" Margin="10,6" BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="1" CornerRadius="4" MinHeight="80">
            <Grid>
                <ScrollViewer x:Name="TextScrollViewer" VerticalScrollBarVisibility="Auto">
                    <RichTextBox x:Name="TextTranscription" IsReadOnly="True" BorderThickness="0" FontSize="20" Padding="4" Foreground="{DynamicResource TextBrush}" Background="Transparent" VerticalScrollBarVisibility="Auto" SelectionChanged="TextTranscription_SelectionChanged">
                        <FlowDocument PagePadding="0"><Paragraph x:Name="TranscriptionParagraph" Margin="0"><Run Text="Select an audio file to begin." Foreground="{DynamicResource TextDimBrush}"/></Paragraph></FlowDocument>
                    </RichTextBox>
                </ScrollViewer>
                <Border x:Name="TranscribeOverlay" Visibility="Collapsed" Background="#80000000" CornerRadius="4">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="TranscribeStatus" Text="Transcribing..." Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <ProgressBar x:Name="TranscribeProgress" IsIndeterminate="True" Width="200" Height="20" Foreground="#FF56B4E9"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="5" x:Name="TranslationPanel" Visibility="Collapsed" Margin="10,4,10,16" Padding="8,6,8,12" CornerRadius="4" BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="1" Background="{DynamicResource PanelBackgroundBrush}">
            <Grid x:Name="TranslationInnerGrid">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <TextBlock Grid.Row="0" x:Name="TxtTranslationOriginal" FontSize="11" Foreground="{DynamicResource TextDimBrush}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="1" x:Name="TxtTranslationResult" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"/>
                <Button Grid.Row="2" x:Name="BtnAddToAnki" Content="Add to Anki" Padding="10,4" Margin="0,8,0,0" HorizontalAlignment="Right" Click="BtnAddToAnki_Click" Background="#FFC107" Foreground="#222" FontWeight="Bold" ToolTip="Create Anki flashcards from the selected word/phrase"/>
            </Grid>
        </Border>

        <StatusBar Grid.Row="6" Background="{DynamicResource StatusBarBrush}"><StatusBarItem><TextBlock x:Name="TxtStatus" Text="Ready" Foreground="{DynamicResource TextDimBrush}" FontSize="13"/></StatusBarItem></StatusBar>
    </Grid>
</Window>
