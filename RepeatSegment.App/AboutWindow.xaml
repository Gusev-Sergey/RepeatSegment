<Window x:Class="RepeatSegment.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About RepeatSegment"
        Width="480" Height="340" MinWidth="400" MinHeight="300" SizeToContent="Manual"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI" FontSize="12pt"
        Loaded="Window_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" FontSize="22" FontWeight="Bold" Margin="0,0,0,10"
                   Foreground="{DynamicResource TextBrush}">RepeatSegment</TextBlock>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,6" x:Name="TxtTagline"/>
                <TextBlock FontSize="13" Foreground="{DynamicResource TextDimBrush}"
                           TextWrapping="Wrap" x:Name="TxtVersion"/>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Margin="0,8,0,4">
            <TextBlock FontSize="13" TextWrapping="Wrap">
                🌐 <Hyperlink x:Name="LinkWebsite" Click="LinkWebsite_Click" Foreground="{DynamicResource SliderAccentBrush}">repeat-segment.lovable.app</Hyperlink>
            </TextBlock>
            <TextBlock FontSize="13" TextWrapping="Wrap" Margin="0,2,0,0">
                📂 <Hyperlink x:Name="LinkGitHub" Click="LinkGitHub_Click" Foreground="{DynamicResource SliderAccentBrush}">github.com/Gusev-Sergey/RepeatSegment</Hyperlink>
            </TextBlock>
        </StackPanel>
        <Button Grid.Row="3" x:Name="BtnClose" Content="OK" Width="80" Height="30"
                Margin="0,12,0,0" HorizontalAlignment="Right"
                Click="BtnClose_Click" IsDefault="True"/>
    </Grid>
</Window>
