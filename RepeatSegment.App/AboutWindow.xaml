<Window x:Class="RepeatSegment.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About RepeatSegment"
        Width="500" Height="360" MinWidth="420" MinHeight="320"
        SizeToContent="WidthAndHeight"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI" FontSize="12pt"
        Loaded="Window_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" FontSize="22" FontWeight="Bold" Margin="0,0,0,10"
                   Foreground="{DynamicResource TextBrush}">RepeatSegment</TextBlock>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,6" x:Name="TxtTagline"/>
                <TextBlock FontSize="13" Foreground="{DynamicResource TextDimBrush}"
                           TextWrapping="Wrap" x:Name="TxtVersion"/>
            </StackPanel>
        </ScrollViewer>
        <Button Grid.Row="2" x:Name="BtnClose" Content="OK" Width="80" Height="30"
                Margin="0,12,0,0" HorizontalAlignment="Right"
                Click="BtnClose_Click" IsDefault="True"/>
    </Grid>
</Window>
