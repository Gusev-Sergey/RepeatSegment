<Window x:Class="RepeatSegment.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About RepeatSegment"
        Width="440" Height="320" MinWidth="360" MinHeight="280"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI" FontSize="12pt"
        Loaded="Window_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" FontSize="22" FontWeight="Bold" Margin="0,0,0,12"
                   Foreground="{DynamicResource TextBrush}">RepeatSegment</TextBlock>
        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock FontSize="14" Foreground="{DynamicResource TextDimBrush}" TextWrapping="Wrap" Margin="0,0,0,6"
                       Text="Study English with Audio Books"/>
            <TextBlock FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,4,0,0"
                       x:Name="TxtVersion"/>
            <TextBlock FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,2,0,0"
                       x:Name="TxtTech"/>
            <TextBlock FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,8,0,0">
                <Hyperlink NavigateUri="https://github.com/Gusev-Sergey/RepeatSegment" RequestNavigate="Hyperlink_RequestNavigate">
                    github.com/Gusev-Sergey/RepeatSegment
                </Hyperlink>
            </TextBlock>
        </StackPanel>
        <Button Grid.Row="2" x:Name="BtnClose" Content="OK" Width="80" Height="30"
                Margin="0,8,0,0" HorizontalAlignment="Right"
                Click="BtnClose_Click" IsDefault="True"/>
    </Grid>
</Window>
