<Window x:Class="RepeatSegment.App.ManualWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RepeatSegment — User Guide"
        Width="700" Height="720"
        MinWidth="460" MinHeight="480"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        FontFamily="Segoe UI"
        FontSize="12pt">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <RichTextBox x:Name="TxtGuide" IsReadOnly="True" BorderThickness="0"
                         Background="Transparent" FontSize="13"
                         Foreground="{DynamicResource TextBrush}">
                <FlowDocument x:Name="GuideDocument"/>
            </RichTextBox>
        </ScrollViewer>
        <Button Grid.Row="1" Content="Close" Width="80" Height="30"
                Margin="0,12,0,0" HorizontalAlignment="Right"
                Click="BtnClose_Click" IsCancel="True"/>
    </Grid>
</Window>
