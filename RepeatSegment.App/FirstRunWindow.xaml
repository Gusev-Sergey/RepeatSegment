<Window x:Class="RepeatSegment.App.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RepeatSegment — Setup"
        Width="340" Height="220"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI" FontSize="14pt">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Choose language / Выберите язык"
                   FontSize="18" FontWeight="Bold" TextWrapping="Wrap"
                   HorizontalAlignment="Center" Margin="0,10,0,20"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button x:Name="BtnEn" Content="English" Width="120" Height="50" Margin="10"
                    FontSize="16" Click="BtnEn_Click" Cursor="Hand"/>
            <Button x:Name="BtnRu" Content="Русский" Width="120" Height="50" Margin="10"
                    FontSize="16" Click="BtnRu_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
