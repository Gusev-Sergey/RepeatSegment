<Window x:Class="RepeatSegment.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transcription Settings"
        Width="520" Height="660"
        MinWidth="460" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI"
        FontSize="11pt">
    <Window.Resources>
        <!-- Styles only (brushes injected from code-behind) -->
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SeparatorBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="2"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource ButtonHoverBrush}"/>
        </Style>


        <!-- ComboBox with themed ToggleButton -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          Foreground="{TemplateBinding Foreground}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding Path=IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"
                                                                  Margin="6,2,20,2"/>
                                                <Path x:Name="Arrow" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                      Margin="0,0,8,0" Fill="{TemplateBinding Foreground}"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="8,3,24,3" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Slide">
                                <Grid MaxHeight="{TemplateBinding MaxDropDownHeight}" MinWidth="{TemplateBinding ActualWidth}">
                                    <Border x:Name="DropDownBorder"
                                            Background="{DynamicResource InputBgBrush}"
                                            BorderBrush="{DynamicResource InputBorderBrush}"
                                            BorderThickness="1"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonPressedBrush}"/>
                </Trigger>
                <Trigger Property="IsDefault" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SliderAccentBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Active providers (checked = try in order)">
            <StackPanel Margin="4">
                <CheckBox x:Name="CbVkCloud" Content="VK Cloud" Visibility="Collapsed"/>
                <CheckBox x:Name="CbYandex" Content="Yandex SpeechKit" Visibility="Collapsed"/>
                <CheckBox x:Name="CbSalute" Content="SaluteSpeech (Sber)" Visibility="Collapsed"/>
                <CheckBox x:Name="CbAssemblyAi" Content="AssemblyAI (VPN required from Russia)"/>
                <CheckBox x:Name="CbDeepgram" Content="Deepgram"/>
            </StackPanel>
        </GroupBox>

        <TextBlock Grid.Row="1" Text="───── API Keys ─────" FontSize="12"
                   Foreground="{DynamicResource TextDimBrush}" Margin="0,10,0,4"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,4">
                <!-- VK / Yandex / Salute hidden — not yet implemented -->
                <StackPanel Visibility="Collapsed">
                    <TextBlock Text="───── VK Cloud ─────" FontSize="11" Foreground="{DynamicResource TextDimBrush}" Margin="0,8,0,2"/>
                    <TextBlock Text="Token:" Margin="0,2,0,0"/>
                    <TextBox x:Name="TxtVkToken" Margin="0,0,0,8"/>
                </StackPanel>
                <StackPanel Visibility="Collapsed">
                    <TextBlock Text="───── Yandex Cloud ─────" FontSize="11" Foreground="{DynamicResource TextDimBrush}" Margin="0,8,0,2"/>
                    <TextBlock Text="API key:" Margin="0,2,0,0"/>
                    <TextBox x:Name="TxtYandexKey" Margin="0,0,0,8"/>
                    <TextBlock Text="Folder ID:" Margin="0,2,0,0"/>
                    <TextBox x:Name="TxtYandexFolderId" Margin="0,0,0,8"/>
                </StackPanel>
                <StackPanel Visibility="Collapsed">
                    <TextBlock Text="───── SaluteSpeech ─────" FontSize="11" Foreground="{DynamicResource TextDimBrush}" Margin="0,8,0,2"/>
                    <TextBlock Text="Client ID:" Margin="0,2,0,0"/>
                    <TextBox x:Name="TxtSaluteClientId" Margin="0,0,0,8"/>
                    <TextBlock Text="Client Secret:" Margin="0,2,0,0"/>
                    <TextBox x:Name="TxtSaluteSecret" Margin="0,0,0,8"/>
                    <TextBlock Text="Scope:" Margin="0,2,0,0"/>
                    <TextBox x:Name="TxtSaluteScope" Text="SALUTE_SPEECH_PERS" Margin="0,0,0,8"/>
                    <TextBlock Text="Language:" Margin="0,2,0,0"/>
                    <ComboBox x:Name="CmbSaluteLang" Margin="0,0,0,8">
                        <ComboBoxItem Content="English — en-US" Tag="en-US"/>
                        <ComboBoxItem Content="Русский — ru-RU" Tag="ru-RU" IsSelected="True"/>
                        <ComboBoxItem Content="Қазақша — kk-KZ" Tag="kk-KZ"/>
                        <ComboBoxItem Content="Кыргызча — ky-KG" Tag="ky-KG"/>
                        <ComboBoxItem Content="O'zbek — uz-UZ" Tag="uz-UZ"/>
                    </ComboBox>
                    <TextBlock Text="Profile ID:" Margin="0,2,0,0"/>
                    <TextBox x:Name="TxtSaluteProfileId" Margin="0,0,0,8"/>
                </StackPanel>

                <TextBlock Text="───── AssemblyAI ─────" FontSize="11"
                           Foreground="{DynamicResource TextDimBrush}" Margin="0,4,0,2"/>
                <TextBlock FontSize="12" Margin="0,0,0,2">
                    Get free API key at <Hyperlink NavigateUri="https://www.assemblyai.com" RequestNavigate="Hyperlink_RequestNavigate">assemblyai.com</Hyperlink></TextBlock>
                <TextBlock Text="API key:" Margin="0,2,0,0"/>
                <TextBox x:Name="TxtAssemblyAiKey" Margin="0,0,0,4"/>
                <TextBlock Text="⚠ AssemblyAI blocked in Russia — use VPN" FontSize="11"
                           Foreground="{DynamicResource TextDimBrush}" Margin="0,0,0,8"/>

                <TextBlock Text="───── Deepgram ─────" FontSize="11"
                           Foreground="{DynamicResource TextDimBrush}" Margin="0,4,0,2"/>
                <TextBlock FontSize="12" Margin="0,0,0,2">
                    Get free API key at <Hyperlink NavigateUri="https://deepgram.com" RequestNavigate="Hyperlink_RequestNavigate">deepgram.com</Hyperlink></TextBlock>
                <TextBlock Text="API key:" Margin="0,2,0,0"/>
                <TextBox x:Name="TxtDeepgramKey" Margin="0,0,0,8"/>

                <Separator Margin="0,4,0,4" Background="{DynamicResource SeparatorBrush}"/>

                <TextBlock Text="───── Translation ─────" FontSize="13"
                           Foreground="{DynamicResource TextBrush}" Margin="0,4,0,2" FontWeight="Bold"/>

                <StackPanel Margin="0,2">
                    <CheckBox x:Name="CbTranslationGoogle" Content="Google Translate (translate.googleapis.com — free, no key needed)"
                              Checked="CbTranslationGoogle_Checked" Unchecked="CbTranslationGoogle_Unchecked"/>
                    <CheckBox x:Name="CbTranslationYandex" Content="Yandex.Translate (requires API key + Folder ID)"
                              Checked="CbTranslationYandex_Checked" Unchecked="CbTranslationYandex_Unchecked"
                              Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel x:Name="PanelYandexTranslate" Visibility="Collapsed" Margin="0,6,0,0">
                    <TextBlock Text="API key:" FontSize="11"
                               Foreground="{DynamicResource TextDimBrush}" Margin="0,2,0,0"/>
                    <TextBox x:Name="TxtYandexTranslateKey" Margin="0,0,0,4"/>
                    <TextBlock Text="Folder ID:" FontSize="11"
                               Foreground="{DynamicResource TextDimBrush}" Margin="0,2,0,0"/>
                    <TextBox x:Name="TxtYandexTranslateFolderId" Margin="0,0,0,8"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Margin="0,4">
            <TextBlock Text="───── General ─────" FontSize="11"
                       Foreground="{DynamicResource TextDimBrush}" Margin="0,8,0,2"/>
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Transcription language:"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="1" x:Name="CmbTranscriptionLang" Margin="0,0,0,4"/>
            </Grid>
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Chunk minutes:"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" x:Name="TxtChunkMinutes" Text="10"/>
            </Grid>
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Highlight latency (s):"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" x:Name="TxtPlaybackLatency" Text="0.32"/>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Height="30" Click="BtnOk_Click" IsDefault="True" Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="80" Height="30" Click="BtnCancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
